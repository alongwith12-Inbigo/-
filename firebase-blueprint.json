{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "야외 행사 및 학습",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "행사 고유 ID"
        },
        "title": {
          "type": "string",
          "description": "행사명"
        },
        "date": {
          "type": "string",
          "description": "행사 일자 (YYYY-MM-DD)"
        },
        "students": {
          "type": "array",
          "description": "행사에 참여하는 학생들의 출석 기록 목록"
        },
        "createdAt": {
          "type": "string",
          "description": "생성 일시"
        }
      },
      "required": ["id", "title", "date", "students", "createdAt"]
    },
    "Roster": {
      "title": "Roster",
      "description": "기본 학생 등록 명단",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "명단 고유 ID (예: default)"
        },
        "students": {
          "type": "array",
          "description": "학생 정보 목록"
        },
        "updatedAt": {
          "type": "string",
          "description": "최종 수정 일시"
        }
      },
      "required": ["id", "students", "updatedAt"]
    }
  },
  "firestore": {
    "events/{eventId}": {
      "schema": "Event",
      "description": "행사별 출석부 정보 및 학생 명단"
    },
    "rosters/{rosterId}": {
      "schema": "Roster",
      "description": "시스템 전체에 등록된 기본 학생 명단"
    }
  }
}
